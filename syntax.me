.tr @"
.uh "Описание входного языка мобильного компилятора Джонсона"
.pp
Компилятор получает на входе текст программы, прошедшей
обработку препроцессором. Кроме текста собственно программы
на языке Си во входном потоке могут содержаться строки вида
.[
# <число> <имя-файла>
.]
причем символ "#" должен стоять в первой позиции.
Посредством таких конструкций препроцессор передает компилятору
информацию о том, к какому исходному файлу и какой строке
относится очередной фрагмент текста.
.pp
При описании синтаксиса используются следующие обозначения:
.ip имя
мета-понятие
.ip @строка@
строка исходного текста
.ip @\\\\@@
символ "двойная кавычка"
.ip |
разделение альтернатив
.ip ()
группирование
.ip []
возможное отсутствие элемента
.ip ?
возможное отсутствие предшествующего элемента
.ip *
повторение предшествующего элемента 0 и более раз
.ip +
повторение предшествующего элемента 1 и более раз
.ip ...
диапазон дискретных значений
.pp
Используемое понятие ASM-СИМВОЛ обозначает любой символ кроме
двойной кавычки и конца строки.
.nh
.na
.ip "файл ="
(внешнее\-определение | ассемблерная\-вставка) *
.ip "ассемблерная\-вставка ="
"\fIasm\fR" "(" "\\"" ASM\-СИМВОЛ * "\\"" ")" ";"
.ip "внешнее\-определение ="
[атрибуты]\ ([список\-внешних\-описаний]\ ";"\ |
описание\-функции тело\-функции)
.ip "атрибуты ="
класс\ тип\ | тип\ класс\ | класс\ | тип\ | класс\ тип\ класс
.ip "класс ="
"\fIauto\fR"\ | "\fIextern\fR"\ | "\fIfortran\fR"\ | "\fIregister\fR"\ | "\fIstatic\fR"\ | "\fItypedef\fR"
.ip "тип ="
простой\-тип\ | простой\-тип\ простой\-тип\ |
простой\-тип\ простой\-тип\ простой\-тип\ |
определение\-структуры\ | определение\-перечисления
.ip "простой\-тип ="
"\fIchar\fR"\ | "\fIdouble\fR"\ | "\fIfloat\fR"\ | "\fIint\fR"\ | "\fIlong\fR"\ | "\fIshort\fR"\ |
"\fIunsigned\fR"\ | "\fIvoid\fR"
.ip "определение\-структуры ="
структура\ имя\ | структура\ [имя]\ "{"\ список\-определений\-типа\ [";"]\ "}"
.ip "структура ="
"\fIstruct\fR"\ | "\fIunion\fR"
.ip "список\-определений\-типа ="
определение\-типа\ (";"\ определение\-типа)\ *
.ip "определение\-типа ="
тип\ [список\-описаний]
.ip "список\-описаний ="
описание\ (","\ описание)\ *
.ip "описание ="
описание\-функции\ |
описание\-данных\ [":"\ константное\-выражение]\ |
":"\ константное\-выражение
.ip "описание\-данных ="
"*"\ описание\-данных\ |
описание\-данных\ "("\ ")"\ |
описание\-данных\ "["\ "]"\ |
описание\-данных\ "["\ константное\-выражение\ "]"\ |
имя\ |
"("\ описание\-данных\ ")"
.ip "описание\-функции ="
"*"\ описание\-функции\ |
описание\-функции\ "("\ ")"\ |
описание\-функции\ "["\ "]"\ |
описание\-функции\ "["\ константное\-выражение\ "]"\ |
"("\ описание\-функции\ ")"\ |
имя\ "("\ список\-имен\ ")"\ |
имя\ "("\ ")"
.ip "список\-внешних\-описаний ="
внешнее\-описание\ (","\ внешнее\-описание)\ *
.ip "внешнее\-описание ="
описание\-данных\ | описание\-функции
.ip "определение\-перечисления ="
"\fIenum\fR"\ [имя]\ "{"\ список\-элементов\-перечисления\ [","]\ "}"\ | "\fIenum\fR"\ имя
.ip "список\-элементов\-перечисления ="
элемент\-перечисления\ (","\ элемент\-перечисления)\ *
.ip "элемент\-перечисления ="
имя\ ["="\ константное\-выражение]
.ip "константное\-выражение ="
выражение
.ip "тело\-функции ="
описание\-аргументов\ *\ составной\-оператор
.ip "описание\-аргументов ="
атрибуты\ [список\-описаний]\ ";"
.ip "составной\-оператор ="
"{"\ (атрибуты\ [список\-внешних\-описаний]\ ";")\ *\ оператор\ *\ "}"
.ip "оператор ="
выражение\ ";"\ |
ассемблерная\-вставка\ |
составной\-оператор\ |
"\fIif\fR"\ "("\ выражение\ ")"\ оператор\ |
"\fIif\fR"\ "("\ выражение\ ")"\ оператор\ "\fIelse\fR"\ оператор\ |
"\fIwhile\fR"\ "("\ выражение\ ")"\ оператор\ |
"\fIdo\fR"\ оператор\ "\fIwhile\fR"\ "("\ выражение\ ")"\ ";"\ |
"\fIfor\fR"\ "("\ выражение\ ?\ ";"\ выражение\ ?\ ";"\ выражение\ ?\ ")" оператор\ |
"\fIswitch\fR"\ "("\ выражение\ ")"\ оператор\ |
"\fIbreak\fR"\ ";"\ |
"\fIcontinue\fR"\ ";"\ |
"\fIreturn\fR"\ выражение\ ?\ ";"\ |
"\fIgoto\fR"\ имя\ ";"\ |
";"\ |
метка\ оператор
.ip "метка ="
имя\ ":"\ | "\fIcase\fR"\ выражение\ ":"\ | "\fIdefault\fR"\ ":"
.ip "выражение ="
выражение\ "?"\ выражение\ ":"\ выражение\ |
выражение\ бинарная\-операция\ выражение\ |
терм
.ip "бинарная\-операция ="
"<="\ | ">="\ | "<"\ | ">"\ | ","\ | "/"\ | "%"\ | "+"\ | "\-"\ | "<<"\ |
">>"\ | "*"\ | "=="\ | "!="\ | "&"\ | "|"\ | "^"\ | "&&"\ | "||"\ |
"*="\ | "/="\ | "%="\ | "+="\ | "\-="\ | ">>="\ | "<<="\ | "&="\ |
"|="\ | "^="\ | "="\ | "=\-"\ | "=*"\ | "=&"\ | "=+"\ | "=/"\ | "=%"\ |
"=|"\ | "=^"\ | "=<"\ | "=>"
.ip "терм ="
терм\ ("++"\ |\ "\-\-")\ | ("++"\ |\ "\-\-")\ терм\ | "*"\ терм\ | "&"\ терм\ |
"\-"\ терм\ | "!"\ терм\ | "^"\ терм\ | "\fIsizeof\fR"\ терм\ |
"("\ тип\ [пустое\-описание]\ ")"\ терм\ |
"\fIsizeof\fR"\ "("\ тип\ [пустое\-описание]\ ")"\ |
терм\ "["\ выражение\ "]"\ |
терм\ "("\ ")"\ |
терм\ "("\ выражение\ (","\ выражение)\ *\ ")"\ |
терм\ "\->"\ имя\ |
терм\ "."\ имя\ |
имя\ |
целое\ |
вещественное\ |
строка\ |
"("\ выражение\ ")"
.ip "пустое\-описание ="
"("\ [пустое\-описание]\ ")"\ "("\ ")"\ |
"*"\ пустое\-описание\ |
пустое\-описание\ "["\ [константное\-выражение]\ "]"\ |
"("\ [пустое\-описание]\ ")"
.ip "имя ="
буква\ (буква\ |\ цифра)\ *
.ip "буква ="
"_"\ | "A"..."Z"\ | "a"..."z"
.ip "цифра ="
"0"..."9"
.ip "целое ="
"'"\ символ\ +\ "'"\ | "0"\ ("x"\ |\ "X")\ шестнадцатеричная\-цифра\ *\ |
"0"\ восьмеричная\-цифра\ *\ | цифра\ +
.ip "шестнадцатеричная\-цифра ="
цифра\ | "a"..."f"\ | "A"..."F"
.ip "восьмеричная\-цифра ="
"0"..."7"
.ip "строка ="
"\\""\ символ\ *\ "\\""
.ip "вещественное ="
цифра\ *\ ["."\ [цифра\ *]\ [("e"\ |\ "E")\ ["+"\ |\ "\-"]\ цифра\ *]
.hy
.ad
.pp
Приведенная грамматика не может служить определением языка Си.
Это всего лишь иллюстрация, описывающая набор конструкций, которые
синтаксический анализатор компилятора считает "правильными".
Многие из них будут отвергнуты на этапе семантической проверки.
Например, конструкция
.[
int short unsigned x;
.]
правильна, а
.[
int int int x;
.]
ошибочна, хотя обе они соответствуют приведенной грамматике.
.pp
Тем не менее, приведенное выше описание может быть полезным
для понимания тонких мест языка.
